{
  "name": "tmdb-mteam-hub-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vite build",
    "check": "vp check",
    "preview": "vp preview",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:fixture": "node --test e2e/fixture-server.test.mjs",
    "generate:api-contracts": "node scripts/generate-api-contracts.mjs",
    "check:api-contracts": "node scripts/generate-api-contracts.mjs --check",
    "check:openapi-parity": "node scripts/ci/verify-openapi-parity.mjs",
    "typecheck:api": "tsc -p frontend/jsconfig.api.json",
    "verify:frontend": "npm run check:api-contracts && npm run check:openapi-parity && npm run test && npm run typecheck:api && npm run check -- frontend vite.config.ts tailwind.config.js postcss.config.cjs && npm run build"
  },
  "dependencies": {
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "daisyui": "^4.12.24",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=10.9.8",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "npm@11.17.0"
}
